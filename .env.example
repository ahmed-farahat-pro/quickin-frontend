# Base URL of the QuickIn backend API.
# Local dev default:
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000

# In production (Vercel), set this to the deployed backend URL, e.g.:
# NEXT_PUBLIC_API_URL=https://quickin-backend.vercel.app

# --- Payments (Paymob) -------------------------------------------------------
# Paymob lives ENTIRELY on quickin-backend (keys + webhook = single source of truth).
# The web "Pay now" flow proxies to NEXT_PUBLIC_API_URL above, forwarding the user's
# token, so this project needs NO Paymob keys. Two requirements for it to work:
#   1) NEXT_PUBLIC_API_URL must point at the deployed backend (not localhost) in prod.
#   2) AUTH_SECRET below MUST be identical to the backend's AUTH_SECRET, so the token
#      this app issues verifies on the backend. The two projects issue tokens
#      independently today, so they may currently DIFFER — set both to the same value.
# AUTH_SECRET=must-match-the-backend-exactly
